{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "src/app/**/*.{ts,tsx}",
    "src/domain/publicApi.ts",
    "src/application/publicApi.ts",
    "src/infrastructure/publicApi.ts",
    "open-next.config.ts"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "scripts/**/*.{js,mjs,ts}",
    "*.config.{js,mjs,ts}"
  ],
  "ignore": [
    "scripts/print-dups.js"
  ],
  "ignoreDependencies": [
    "^tailwindcss$"
  ]
}