{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "src/app/layout.tsx",
    "src/app/page.tsx",
    "src/app/**/page.tsx",
    "src/app/**/route.ts",
    "next.config.ts",
    "open-next.config.ts"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "scripts/**/*.{js,mjs,ts}",
    "*.config.{js,mjs,ts}"
  ],
  "ignore": [
    ".next/**",
    ".open-next/**",
    "node_modules/**",
    "public/**",
    "scripts/analyze_deps.js",
    "scripts/print-dups.js"
  ],
  "ignoreDependencies": [
    "^@opennextjs/cloudflare$",
    "^tailwindcss$",
    "^wrangler$"
  ]
}